{
  "name": "medprotocol-core",
  "version": "0.7.9",
  "description": "Medical protocol workflows, calculation logic, and CLI for Claude Code",
  "workspaces": [
    "packages/medprotocol",
    "packages/medical-protocol"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build -w packages/medprotocol",
    "build:installer": "npm run build -w packages/medical-protocol",
    "medprotocol": "node packages/medprotocol/dist/index.js",
    "version:bump": "bash scripts/bump-version.sh",
    "drift:check": "node scripts/drift-check.js",
    "push": "bash scripts/git/push.sh",
    "release": "bash scripts/npm/release.sh"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
